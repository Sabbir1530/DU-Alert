# App
APP_PORT=3000
NODE_ENV=development

# PostgreSQL
DB_NAME=dualert
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
POSTGRES_DB=postgres
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=5000

# JWT
JWT_SECRET=change_this_secret
JWT_EXPIRE=7d

# Email (for nodemailer)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-password

# OpenRouter API (for AI-powered complaint summaries)
# Keep the variable name as OPENAI_API_KEY for compatibility in code.
OPENAI_API_KEY=YOUR_OPENROUTER_KEY
# Optional: override model used for complaint summaries.
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional: override provider base URL (default is OpenRouter v1).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional but recommended for OpenRouter ranking/analytics.
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_NAME=DU Alert

# CORS origin (optional)
CORS_ORIGIN=http://localhost:8080

